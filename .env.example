# ---- Clerk (Authentication) ----
# From https://dashboard.clerk.com -> your app -> API Keys
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Point Clerk at the in-app auth pages.
PUBLIC_CLERK_SIGN_IN_URL=/sign-in
PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ---- Firebase Admin (Firestore) ----
# From Firebase Console -> Project Settings -> Service accounts ->
# "Generate new private key". Open the downloaded JSON and copy the values.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project-id.iam.gserviceaccount.com
# Keep the literal \n sequences from the JSON; they are converted at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
