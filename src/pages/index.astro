---
import Layout from "../layouts/Layout.astro";
import DriverCard from "../components/DriverCard.astro";
import { listDrivers, type Driver } from "../lib/drivers";
import { listRequests } from "../lib/requests";
import { popularRoutes } from "../lib/routes";

// Live data powers the stats, popular routes and recent rides. Fails soft so the
// page always renders even if Firestore is unreachable.
let drivers: Driver[] = [];
let requestCount = 0;
try {
  drivers = await listDrivers();
} catch {
  drivers = [];
}
try {
  requestCount = (await listRequests()).length;
} catch {
  requestCount = 0;
}

const rideCount = drivers.length;
const seatCount = drivers.reduce((n, d) => n + (d.seats || 0), 0);
const areaCount = new Set(
  drivers.flatMap((d) =>
    [d.fromLocation, d.toLocation, ...d.stops]
      .map((s) => s.trim().toLowerCase())
      .filter(Boolean)
  )
).size;

// Most-offered routes (city-scoped, so each links to its indexable route page).
const popular = popularRoutes(drivers, { limit: 6 });

const recentRides = drivers.slice(0, 3);

const stats = [
  { value: rideCount, label: "Rides on offer", suffix: "" },
  { value: seatCount, label: "Seats available", suffix: "" },
  { value: requestCount, label: "Riders looking", suffix: "" },
  { value: 0, label: "Commission charged", prefix: "", suffix: "%" },
];

const faqs = [
  {
    q: "Is Carpool free to use?",
    a: "Yes. Listing a ride and finding one are both completely free. Any fare or fuel contribution is agreed directly between the driver and rider — we never take a cut.",
  },
  {
    q: "How do I contact a driver?",
    a: "Every ride card has a one-tap WhatsApp button (with a pre-filled message) and a call button. You arrange pickup points, timing and cost between yourselves.",
  },
  {
    q: "Do I need an account to search?",
    a: "No — browsing and searching rides is open to everyone. You only sign in when you want to publish a ride as a driver.",
  },
  {
    q: "How accurate are the pickup locations?",
    a: "Drivers pin their exact pickup and drop-off on a map when they register, so what you see on the map is where they actually start and end.",
  },
];

const howSteps = [
  {
    n: "01",
    t: "Drivers register",
    d: "Car owners sign in and pin their car, route, timings and a contact number in under a minute.",
  },
  {
    n: "02",
    t: "Riders search",
    d: "Search by home and drop-off to instantly see drivers heading your way on your schedule.",
  },
  {
    n: "03",
    t: "Connect directly",
    d: "Call or WhatsApp the driver and finalise the arrangement between yourselves. No middleman.",
  },
];

const homepageSchema = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((f) => ({
      "@type": "Question",
      name: f.q,
      acceptedAnswer: { "@type": "Answer", text: f.a },
    })),
  },
  {
    "@context": "https://schema.org",
    "@type": "HowTo",
    name: "How Carpool works",
    description:
      "Three steps to share a daily commute on Carpool — register, search, connect.",
    step: howSteps.map((s, i) => ({
      "@type": "HowToStep",
      position: i + 1,
      name: s.t,
      text: s.d,
    })),
  },
];
---

<Layout
  title="Carpool — Pakistan's free carpooling marketplace"
  description="Share your daily commute in Karachi, Lahore, Islamabad and beyond. Drivers post their routes, riders find matches, and you connect on WhatsApp — zero commission, no middleman."
  canonical="/"
  schema={homepageSchema}
>
  <!-- ================= HERO ================= -->
  <section class="hero">
    <div class="hero-copy" data-reveal>
      <span class="eyebrow">Daily commute, shared</span>
      <h1>
        Going the same way?<br />
        <span class="hl">Share the ride.</span>
      </h1>
      <p class="sub">
        Drivers post their route and timings. Riders search by where they live
        and where they’re headed — then connect directly to split the cost.
      </p>

      <form class="search" method="GET" action="/drivers">
        <div class="search-fields">
          <div class="field">
            <label for="from">From</label>
            <div class="input-icon">
              <span class="pin pin-start" aria-hidden="true"></span>
              <input id="from" name="from" placeholder="Your home area" />
            </div>
          </div>
          <span class="search-arrow" aria-hidden="true">→</span>
          <div class="field">
            <label for="to">To</label>
            <div class="input-icon">
              <span class="pin pin-end" aria-hidden="true"></span>
              <input id="to" name="to" placeholder="Drop-off area" />
            </div>
          </div>
        </div>
        <button type="submit" class="btn btn-primary search-btn">
          Find rides
        </button>
      </form>

      {
        popular.length > 0 && (
          <div class="quick-routes">
            <span class="muted">Popular:</span>
            {popular.slice(0, 4).map((r) => (
              <a class="route-chip" href={r.href}>
                {r.from} → {r.to}
              </a>
            ))}
          </div>
        )
      }

      <div class="under-search">
        <button type="button" id="near-me" class="near-me-btn">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M12 21s-7-5.2-7-11a7 7 0 1 1 14 0c0 5.8-7 11-7 11Z" stroke-linejoin="round"></path>
            <circle cx="12" cy="10" r="2.4"></circle>
          </svg>
          <span id="near-me-label">Find rides near me</span>
        </button>
        <span class="muted dot-sep">
          {rideCount > 0 && `${rideCount} ${rideCount === 1 ? "ride" : "rides"} available · `}
          <a href="/drivers">Browse all →</a>
        </span>
      </div>
    </div>

    <div class="hero-card" aria-hidden="true" data-reveal>
      <div class="map-card card">
        <div class="route-line">
          <span class="node start"></span>
          <span class="thread"></span>
          <span class="node mid"></span>
          <span class="thread"></span>
          <span class="node end"></span>
          <span class="drive-car">
            <svg viewBox="0 0 40 24" width="36" height="22">
              <path d="M3 16c-1.1 0-2-.9-2-2v-1.5c0-.8.4-1.5 1.1-1.9l3-1.7 3.2-3.1C9 4.3 9.9 4 10.8 4h13.4c.9 0 1.8.4 2.4 1.1l3.4 4 5.1 1.2c1.1.3 1.9 1.3 1.9 2.4V14c0 1.1-.9 2-2 2H3Z" fill="#16704a"></path>
              <path d="M11 5.5h12.6c.6 0 1.1.2 1.5.7l2.7 3.1H8.2l2-2.7c.2-.7.4-1.1.8-1.1Z" fill="#cfe7d6"></path>
              <circle cx="11" cy="16.5" r="3.2" fill="#1d1b14"></circle>
              <circle cx="11" cy="16.5" r="1.3" fill="#fff"></circle>
              <circle cx="29" cy="16.5" r="3.2" fill="#1d1b14"></circle>
              <circle cx="29" cy="16.5" r="1.3" fill="#fff"></circle>
            </svg>
          </span>
        </div>
        <div class="route-labels">
          <div><strong>Gulshan</strong><span class="muted">08:00 pickup</span></div>
          <div class="ml-auto right">
            <strong>Downtown</strong><span class="muted">08:35 arrival</span>
          </div>
        </div>
        <div class="map-driver">
          <div class="dp">A</div>
          <div>
            <strong>Ayesha · Corolla</strong>
            <span class="muted">3 seats · Mon–Fri</span>
          </div>
          <span class="tag">Rs 5k/mo</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ================= STATS ================= -->
  <section class="stats" data-reveal>
    {
      stats.map((s) => (
        <div class="stat">
          <span class="stat-num" data-count={s.value} data-suffix={s.suffix ?? ""}>
            {s.prefix ?? ""}{s.value}{s.suffix ?? ""}
          </span>
          <span class="stat-label muted">{s.label}</span>
        </div>
      ))
    }
  </section>

  <!-- ================= HOW IT WORKS ================= -->
  <section class="band">
    <header class="section-head" data-reveal>
      <span class="kicker">Simple by design</span>
      <h2>How it works</h2>
      <p class="muted">Three steps from stranger to carpool.</p>
    </header>
    <div class="steps">
      {
        howSteps.map((s, i) => (
          <article class="card step" data-reveal style={`--d:${i * 80}ms`}>
            <span class="num">{s.n}</span>
            <h3>{s.t}</h3>
            <p class="muted">{s.d}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= AUDIENCE SPLIT ================= -->
  <section class="split">
    <article class="split-card drivers card" data-reveal>
      <span class="split-tag">For drivers</span>
      <h2>Empty seats?<br />Fill them.</h2>
      <p class="muted">
        You’re already making the drive. Offer your spare seats, cover your fuel,
        and share the road with people going your way.
      </p>
      <ul class="ticks">
        <li>Pin your exact pickup &amp; drop-off on the map</li>
        <li>Set your days, times and fare</li>
        <li>Riders reach you on WhatsApp — you stay in control</li>
      </ul>
      <div class="split-actions">
        <a href="/drivers/register" class="btn btn-primary">Offer a ride</a>
        <a href="/requests" class="btn btn-ghost">Find riders</a>
      </div>
    </article>

    <article class="split-card riders card" data-reveal style="--d:80ms">
      <span class="split-tag amber">For riders</span>
      <h2>Skip the wait.<br />Ride together.</h2>
      <p class="muted">
        Find someone already driving your route. Cheaper than a daily cab, kinder
        to the planet, and a familiar face for the commute.
      </p>
      <ul class="ticks">
        <li>Search by your home and destination — results ranked by route match</li>
        <li>Filter for female-only carpools for extra safety</li>
        <li>No driver found? Post a request so drivers come to you</li>
      </ul>
      <div class="split-actions">
        <a href="/drivers" class="btn btn-ghost">Find a ride</a>
        <a href="/requests/post" class="btn btn-ghost">Post a request</a>
      </div>
    </article>
  </section>

  <!-- ================= POPULAR ROUTES ================= -->
  {
    popular.length > 0 && (
      <section class="band">
        <header class="section-head" data-reveal>
          <span class="kicker">Trending</span>
          <h2>Popular routes</h2>
          <p class="muted">Where the carpools are heading right now.</p>
        </header>
        <div class="route-grid" data-reveal>
          {popular.map((r) => (
            <a class="route-tile" href={r.href}>
              <div class="rt-line">
                <span class="rt-dot start" />
                <span class="rt-track" />
                <span class="rt-dot end" />
              </div>
              <div class="rt-names">
                <strong>{r.from}</strong>
                <span class="muted">to {r.to}</span>
              </div>
              <span class="rt-count">{r.count}</span>
            </a>
          ))}
        </div>
      </section>
    )
  }

  <!-- ================= RECENT RIDES ================= -->
  {
    recentRides.length > 0 && (
      <section class="band">
        <header class="section-head row-head" data-reveal>
          <div>
            <span class="kicker">Fresh</span>
            <h2>Recently added rides</h2>
          </div>
          <a href="/drivers" class="btn btn-ghost btn-sm">View all</a>
        </header>
        <div class="recent-grid">
          {recentRides.map((d, i) => (
            <div data-reveal style={`--d:${i * 80}ms`}>
              <DriverCard driver={d} />
            </div>
          ))}
        </div>
      </section>
    )
  }

  <!-- ================= BENEFITS ================= -->
  <section class="band">
    <header class="section-head" data-reveal>
      <span class="kicker">Why carpool</span>
      <h2>Better for your wallet, your city, the planet</h2>
    </header>
    <div class="benefits">
      {
        [
          { i: "💸", t: "Spend less", d: "Split fuel and parking instead of paying for a daily cab or running a second car." },
          { i: "🌍", t: "Cut emissions", d: "One shared car means fewer on the road. Every full seat is a car someone didn’t drive." },
          { i: "🚦", t: "Beat the traffic", d: "Fewer cars, smoother roads, and the carpool lane when your city has one." },
          { i: "🤝", t: "Know your ride", d: "Recurring routes mean familiar faces — not a different stranger every day." },
        ].map((b, i) => (
          <article class="benefit" data-reveal style={`--d:${i * 70}ms`}>
            <span class="b-icon">{b.i}</span>
            <h3>{b.t}</h3>
            <p class="muted">{b.d}</p>
          </article>
        ))
      }
    </div>
  </section>

  <!-- ================= TESTIMONIALS ================= -->
  <section class="band">
    <header class="section-head" data-reveal>
      <span class="kicker">From the road</span>
      <h2>Commuters love it</h2>
    </header>
    <div class="quotes">
      {
        [
          { q: "I cut my monthly commute cost by more than half and stopped fighting for parking. Wish I’d done it sooner.", n: "Bilal", r: "Driver · Clifton → I.I. Chundrigar" },
          { q: "Found a ride from my exact neighbourhood in two minutes. The map made it obvious who was actually nearby.", n: "Sana", r: "Rider · Gulshan → Saddar" },
          { q: "Same three people every morning now. It’s gone from a chore to the best part of my day.", n: "Hamza", r: "Driver · DHA → Korangi" },
        ].map((t, i) => (
          <figure class="quote card" data-reveal style={`--d:${i * 80}ms`}>
            <span class="mark" aria-hidden="true">“</span>
            <blockquote>{t.q}</blockquote>
            <figcaption>
              <span class="qa">{t.n.charAt(0)}</span>
              <span>
                <strong>{t.n}</strong>
                <span class="muted">{t.r}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </section>

  <!-- ================= GET THE APP ================= -->
  <section class="band app-band" data-reveal>
    <div class="app-inner">

      <!-- Left: phone mockup -->
      <div class="app-visual" aria-hidden="true">
        <div class="phone-wrap">
          <!-- Notification bubble -->
          <div class="phone-notif">
            <span class="notif-dot"></span>
            New ride: Gulshan → DHA
          </div>

          <div class="phone-frame">
            <!-- Camera pill -->
            <div class="phone-camera"></div>

            <div class="phone-screen">
              <!-- Status bar -->
              <div class="pstatus">
                <span class="ptime">9:41</span>
                <span class="picons">
                  <svg viewBox="0 0 24 10" width="18" height="7" fill="currentColor"><rect x="0" y="3" width="3" height="7" rx="1"/><rect x="5" y="1" width="3" height="9" rx="1"/><rect x="10" y="0" width="3" height="10" rx="1"/><rect x="15" y="4" width="7" height="6" rx="1" opacity=".3"/><rect x="15" y="4" width="5" height="6" rx="1"/></svg>
                </span>
              </div>

              <!-- App header -->
              <div class="pheader">
                <img src="/carpool-logo.png" alt="Carpool" class="plogo" />
              </div>

              <!-- Search bar mock -->
              <div class="psearch">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
                <span>Gulshan → Clifton</span>
              </div>

              <!-- Ride cards -->
              <div class="pcard">
                <div class="pcard-left">
                  <div class="pavatar" style="background:linear-gradient(150deg,#16704a,#0f5236)">A</div>
                </div>
                <div class="pcard-body">
                  <div class="pcard-top">
                    <strong>Ayesha</strong>
                    <span class="pstars">★ 4.8</span>
                  </div>
                  <div class="proute">
                    <span class="pdot green"></span>Gulshan-e-Iqbal
                    <span class="pline"></span>
                    <span class="pdot amber"></span>Clifton
                  </div>
                  <div class="ptags">
                    <span class="ptag">Mon–Fri</span>
                    <span class="ptag">3 seats</span>
                    <span class="ptag green">On the way</span>
                  </div>
                </div>
              </div>

              <div class="pcard">
                <div class="pcard-left">
                  <div class="pavatar" style="background:linear-gradient(150deg,#2d6a8f,#1a4a6b)">Z</div>
                </div>
                <div class="pcard-body">
                  <div class="pcard-top">
                    <strong>Zain</strong>
                    <span class="pstars">★ 4.5</span>
                  </div>
                  <div class="proute">
                    <span class="pdot green"></span>DHA Phase 5
                    <span class="pline"></span>
                    <span class="pdot amber"></span>Saddar
                  </div>
                  <div class="ptags">
                    <span class="ptag">Mon–Sat</span>
                    <span class="ptag">2 seats</span>
                  </div>
                </div>
              </div>

              <div class="pcard faded">
                <div class="pcard-left">
                  <div class="pavatar" style="background:linear-gradient(150deg,#8f4a2d,#6b2d1a)">S</div>
                </div>
                <div class="pcard-body">
                  <div class="pcard-top"><strong>Sara</strong><span class="pstars">★ 5.0</span></div>
                  <div class="proute">
                    <span class="pdot green"></span>Nazimabad
                    <span class="pline"></span>
                    <span class="pdot amber"></span>I.I. Chundrigar
                  </div>
                </div>
              </div>
            </div>

            <!-- Home bar -->
            <div class="phone-bar"></div>
          </div>

          <!-- Floating WhatsApp bubble -->
          <div class="phone-wa">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="#fff"><path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Z"/></svg>
            Seat confirmed!
          </div>
        </div>
      </div>

      <!-- Right: benefits -->
      <div class="app-copy">
        <span class="kicker">Now on Android</span>
        <h2>Your commute,<br/>always one tap away</h2>

        <ul class="benefits">
          <li>
            <span class="benefit-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
            </span>
            <div>
              <strong>Instant access, no app store</strong>
              <p>Tap once from your home screen. No 200 MB download, no account hoops — just your rides.</p>
            </div>
          </li>
          <li>
            <span class="benefit-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 6v16l7-4 8 4 7-4V2l-7 4-8-4-7 4z"/><path d="M8 2v16M16 6v16"/></svg>
            </span>
            <div>
              <strong>Browse rides even offline</strong>
              <p>Cached routes load instantly — perfect for spotty mobile data on the morning commute.</p>
            </div>
          </li>
          <li>
            <span class="benefit-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><path d="M12 18h.01"/></svg>
            </span>
            <div>
              <strong>Feels like a real app</strong>
              <p>Full-screen, no browser chrome, smooth navigation — riders and drivers won't know the difference.</p>
            </div>
          </li>
          <li>
            <span class="benefit-icon">
              <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            </span>
            <div>
              <strong>Always up to date</strong>
              <p>Every time you open it, you get the latest listings — no manual updates ever.</p>
            </div>
          </li>
        </ul>

        <div class="app-cta">
          <button class="btn install-btn" id="pwa-install-btn" hidden>
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="M12 15V3m0 12-4-4m4 4 4-4"/><rect x="2" y="17" width="20" height="4" rx="2"/>
            </svg>
            Add to Home Screen
          </button>
          <p class="install-fallback" id="pwa-fallback">
            Open in <strong>Chrome on Android</strong> → tap ⋮ → <strong>Add to Home screen</strong>
          </p>
        </div>
      </div>

    </div>
  </section>

  <!-- ================= FAQ ================= -->
  <section class="band faq-band">
    <header class="section-head" data-reveal>
      <span class="kicker">Good to know</span>
      <h2>Questions, answered</h2>
    </header>
    <div class="faqs" data-reveal>
      {
        faqs.map((f) => (
          <details class="faq">
            <summary>
              {f.q}
              <span class="chev" aria-hidden="true">+</span>
            </summary>
            <p class="muted">{f.a}</p>
          </details>
        ))
      }
    </div>
  </section>

  <!-- ================= CTA ================= -->
  <section class="cta" data-reveal>
    <div class="cta-inner">
      <h2>Your next commute could be shared.</h2>
      <p>Offer your empty seats or find a ride going your way — it’s free to start.</p>
      <div class="cta-actions">
        <a href="/drivers/register" class="btn btn-light">Offer a ride</a>
        <a href="/drivers" class="btn btn-outline">Find a ride</a>
      </div>
    </div>
  </section>
</Layout>

<script>
  interface BeforeInstallPromptEvent extends Event {
    prompt(): Promise<void>;
    userChoice: Promise<{ outcome: "accepted" | "dismissed" }>;
  }

  // Scroll reveal
  const revealEls = document.querySelectorAll<HTMLElement>("[data-reveal]");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  if (reduce) {
    revealEls.forEach((el) => el.classList.add("in"));
  } else {
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add("in");
            io.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
    );
    revealEls.forEach((el) => io.observe(el));
  }

  // Stat counters are server-rendered with their real values so crawlers
  // (and users without JS) see the right numbers — no count-up animation
  // is needed here.

  // "Find rides near me" — capture location, then hand coords to the browse page.
  const nearBtn = document.getElementById("near-me");
  const nearLabel = document.getElementById("near-me-label");
  nearBtn?.addEventListener("click", () => {
    if (!navigator.geolocation) {
      window.location.href = "/drivers";
      return;
    }
    if (nearLabel) nearLabel.textContent = "Locating…";
    (nearBtn as HTMLButtonElement).disabled = true;
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        const { latitude, longitude } = pos.coords;
        window.location.href = `/drivers?lat=${latitude}&lng=${longitude}`;
      },
      () => {
        // Denied or failed — just take them to all rides.
        window.location.href = "/drivers";
      },
      { enableHighAccuracy: true, timeout: 8000 }
    );
  });

  // PWA install prompt
  let deferredPrompt: BeforeInstallPromptEvent | null = null;
  const installBtn = document.getElementById("pwa-install-btn") as HTMLButtonElement | null;
  const fallbackMsg = document.getElementById("pwa-fallback");

  window.addEventListener("beforeinstallprompt", (e) => {
    e.preventDefault();
    deferredPrompt = e as BeforeInstallPromptEvent;
    if (installBtn) {
      installBtn.hidden = false;
      if (fallbackMsg) fallbackMsg.hidden = true;
    }
  });

  installBtn?.addEventListener("click", async () => {
    if (!deferredPrompt) return;
    deferredPrompt.prompt();
    const { outcome } = await deferredPrompt.userChoice;
    if (outcome === "accepted") installBtn.textContent = "Installing…";
    deferredPrompt = null;
  });

  // If already installed, hide the whole section
  window.addEventListener("appinstalled", () => {
    document.querySelector(".app-band")?.remove();
  });
</script>

