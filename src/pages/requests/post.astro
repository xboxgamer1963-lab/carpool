---
import Layout from "../../layouts/Layout.astro";
import RequestForm from "../../components/RequestForm.astro";

const { userId, sessionClaims } = Astro.locals.auth();
const url = new URL(Astro.request.url);
const error = url.searchParams.get("error");

// Prefill name from Clerk session claims if available.
const defaultName: string =
  (sessionClaims?.firstName as string | undefined) ?? "";
---

<Layout title="Post a rider request — Carpool">
  <header class="page-head">
    <div>
      <h1>Post a rider request</h1>
      <p class="muted sub">
        Tell drivers your route, schedule and budget. They'll contact you directly.
      </p>
    </div>
  </header>

  {error && (
    <div class="card notice error">
      <p>{decodeURIComponent(error)}</p>
    </div>
  )}

  <RequestForm action="/api/requests/create" submitLabel="Post request" defaultName={defaultName} />
</Layout>

<style>
  .page-head {
    margin-bottom: 1.6rem;
  }
  .page-head h1 { font-size: clamp(1.9rem, 4vw, 2.5rem); }
  .page-head .sub { margin-top: 0.35rem; }

  .notice {
    padding: 1rem 1.25rem;
    margin-bottom: 1rem;
    border-radius: var(--radius-sm);
  }
  .notice.error {
    border-color: var(--danger-soft);
    background: var(--danger-soft);
    color: var(--danger);
  }
  .notice p { margin: 0; }
</style>
