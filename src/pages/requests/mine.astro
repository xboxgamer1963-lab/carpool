---
import Layout from "../../layouts/Layout.astro";
import RequestCard from "../../components/RequestCard.astro";
import { getRequestsByOwner } from "../../lib/requests";

const { userId } = Astro.locals.auth();
let allRequests = [];
let error: string | null = null;
if (userId) {
  try {
    allRequests = await getRequestsByOwner(userId);
  } catch (e) {
    error = e instanceof Error ? e.message : "Could not load your requests.";
  }
}

const now = Date.now();
const active = allRequests.filter((r) => r.status === "open" && r.expiresAt > now);
const inactive = allRequests.filter((r) => r.status === "closed" || r.expiresAt <= now);
---

<Layout title="My requests — Carpool">
  <header class="page-head">
    <div>
      <h1>My requests</h1>
      <p class="muted sub">Rider requests you've posted.</p>
    </div>
    <a href="/requests/post" class="btn btn-primary">Post another request</a>
  </header>

  {
    error ? (
      <div class="card notice">{error}</div>
    ) : allRequests.length === 0 ? (
      <div class="card notice">
        <span class="notice-emoji" aria-hidden="true">🙋</span>
        <h3>No requests yet</h3>
        <p class="muted">
          <a href="/requests/post">Post a request</a> so drivers heading your way can find you.
        </p>
      </div>
    ) : (
      <>
        {active.length > 0 && (
          <section class="listing-section">
            <div class="grid">
              {active.map((r) => (
                <RequestCard request={r} owned />
              ))}
            </div>
          </section>
        )}

        {inactive.length > 0 && (
          <section class="listing-section expired-section">
            <h2 class="section-heading muted">Closed / expired requests</h2>
            <div class="grid">
              {inactive.map((r) => (
                <RequestCard request={r} owned />
              ))}
            </div>
          </section>
        )}
      </>
    )
  }
</Layout>

<style>
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.6rem;
    flex-wrap: wrap;
  }
  .page-head h1 { font-size: clamp(1.9rem, 4vw, 2.5rem); }
  .page-head .sub { margin-top: 0.35rem; }

  .listing-section { margin-bottom: 2rem; }
  .expired-section { opacity: 0.8; }
  .section-heading {
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.85rem;
  }

  .grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .notice {
    text-align: center;
    padding: 3rem 1.5rem;
  }
  .notice-emoji { font-size: 2.2rem; display: block; margin-bottom: 0.5rem; }
  .notice h3 { font-size: 1.3rem; }
  .notice p { margin: 0.5rem 0 0; }

  @media (max-width: 520px) {
    .page-head { flex-direction: column; align-items: stretch; }
    .page-head .btn { width: 100%; }
  }
</style>
