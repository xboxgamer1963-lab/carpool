---
import Layout from "../../layouts/Layout.astro";
import RequestCard from "../../components/RequestCard.astro";
import { searchRequests, type ScoredRequest } from "../../lib/requests";
import { CITIES, getCity } from "../../lib/cities";

const url = new URL(Astro.request.url);
const p = url.searchParams;
// Driver's own route coords (A→B) used to score requests
const fromLat = parseFloat(p.get("fromLat") ?? "");
const fromLng = parseFloat(p.get("fromLng") ?? "");
const toLat = parseFloat(p.get("toLat") ?? "");
const toLng = parseFloat(p.get("toLng") ?? "");
const fromText = p.get("from")?.trim() ?? "";
const toText = p.get("to")?.trim() ?? "";

const daysParam = p.get("days")?.trim() ?? "";
const days = daysParam ? daysParam.split(",").filter(Boolean) : [];
const genderPref = p.get("genderPref")?.trim() ?? "";
const city = p.get("city")?.trim() ?? "";

const hasCoords = Number.isFinite(fromLat) && Number.isFinite(fromLng);
const hasQuery = hasCoords || Boolean(fromText || toText || days.length || genderPref || city);

let scored: ScoredRequest[] = [];
let error: string | null = null;
try {
  scored = await searchRequests({
    fromLat: Number.isFinite(fromLat) ? fromLat : undefined,
    fromLng: Number.isFinite(fromLng) ? fromLng : undefined,
    toLat: Number.isFinite(toLat) ? toLat : undefined,
    toLng: Number.isFinite(toLng) ? toLng : undefined,
    fromText,
    toText,
    days: days.length ? days : undefined,
    genderPref: genderPref || undefined,
    city: city || undefined,
  });
} catch (e) {
  error = e instanceof Error ? e.message : "Could not load requests.";
}

const hasNearMiss = scored.some((s) => s.isNearMiss);
const DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

const selectedCity = city ? getCity(city) : null;
const pageTitle = selectedCity
  ? `Riders looking for a carpool in ${selectedCity.name} | Carpool`
  : "Riders looking for a carpool — Pakistan | Carpool";
const pageDescription = selectedCity
  ? `${scored.length} ${scored.length === 1 ? "rider is" : "riders are"} looking for a daily carpool in ${selectedCity.name}. Drivers heading the same way can connect directly — zero commission.`
  : "Riders posting their pickup, destination and schedule — drivers heading the same way can connect directly on WhatsApp. Zero commission, no middleman.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical="/requests"
>
  <header class="page-head">
    <div>
      <h1>Riders looking for a driver</h1>
      <p class="muted sub">
        {
          error
            ? "We couldn't reach the listings."
            : `${scored.length} ${scored.length === 1 ? "rider" : "riders"} ${hasQuery ? "match your route" : "looking for a carpool"}${hasNearMiss ? " (showing nearest matches)" : ""}`
        }
      </p>
    </div>
    <a href="/requests/post" class="btn btn-ghost btn-sm">Post a request</a>
  </header>

  <!-- Search form: driver enters their A→B to find matching riders -->
  <form class="filter card" method="GET" action="/requests" id="search-form">
    <p class="filter-hint muted">Enter your route to find riders along the way.</p>
    <div class="filter-row">
      <div class="filter-field filter-field-city">
        <label for="city">City</label>
        <select id="city" name="city" onchange="this.form.submit()">
          <option value="" selected={!city}>All cities</option>
          {CITIES.map((c) => (
            <option value={c.slug} selected={city === c.slug}>{c.name}</option>
          ))}
        </select>
      </div>
      <div class="filter-field">
        <label for="from">Your pickup</label>
        <div class="ic">
          <span class="pin start"></span>
          <input id="from" name="from" value={fromText} placeholder="Where you start" autocomplete="off" />
          <input type="hidden" name="fromLat" id="fromLat" value={Number.isFinite(fromLat) ? fromLat : ""} />
          <input type="hidden" name="fromLng" id="fromLng" value={Number.isFinite(fromLng) ? fromLng : ""} />
          <ul class="suggestions" id="from-suggestions" hidden></ul>
        </div>
      </div>
      <div class="filter-field">
        <label for="to">Your destination</label>
        <div class="ic">
          <span class="pin end"></span>
          <input id="to" name="to" value={toText} placeholder="Where you're going" autocomplete="off" />
          <input type="hidden" name="toLat" id="toLat" value={Number.isFinite(toLat) ? toLat : ""} />
          <input type="hidden" name="toLng" id="toLng" value={Number.isFinite(toLng) ? toLng : ""} />
          <ul class="suggestions" id="to-suggestions" hidden></ul>
        </div>
      </div>
      <div class="filter-actions">
        <button type="submit" class="btn btn-primary">Find riders</button>
        {hasQuery && <a href="/requests" class="btn btn-ghost">Clear</a>}
      </div>
    </div>

    <details class="extra-filters" id="extra-filters">
      <summary class="extra-toggle">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M7 12h10M11 18h2"/>
        </svg>
        Filters
        {(days.length > 0 || genderPref) && <span class="filter-dot"></span>}
      </summary>
      <div class="extra-content">
        <div class="extra-group">
          <span class="extra-label">Days</span>
          <div class="day-chips">
            {DAYS.map((d) => (
              <label class="day-chip">
                <input type="checkbox" name="days-cb" value={d} checked={days.includes(d)} data-day={d} />
                <span>{d}</span>
              </label>
            ))}
          </div>
          <input type="hidden" name="days" id="days-hidden" value={daysParam} />
        </div>
        <div class="extra-group">
          <span class="extra-label">Preference</span>
          <div class="pref-radios">
            {[
              { v: "", label: "Any" },
              { v: "female_only", label: "Female only" },
              { v: "male_only", label: "Male only" },
            ].map(({ v, label }) => (
              <label class="pref-radio">
                <input type="radio" name="genderPref" value={v} checked={genderPref === v} />
                <span>{label}</span>
              </label>
            ))}
          </div>
        </div>
      </div>
    </details>
  </form>

  {
    error ? (
      <div class="card notice error">
        <h3>Couldn't load requests</h3>
        <p class="muted">{error}</p>
      </div>
    ) : scored.length === 0 ? (
      <div class="card notice">
        <span class="notice-emoji" aria-hidden="true">🙋</span>
        <h3>No rider requests{hasQuery ? " on your route" : " yet"}</h3>
        <p class="muted">
          Check back soon, or{" "}
          <a href="/drivers">browse driver listings</a> instead.
        </p>
      </div>
    ) : (
      <div class="grid">
        {scored.map(({ request, detourKm, isNearMiss }) => (
          <RequestCard request={request} detourKm={detourKm} isNearMiss={isNearMiss} />
        ))}
      </div>
    )
  }
</Layout>

<script>
  const NOMINATIM = "https://nominatim.openstreetmap.org/search";
  interface Suggestion { display_name: string; lat: string; lon: string; }

  function setupAutocomplete(inputId: string, sugId: string, latId: string, lngId: string) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const sug = document.getElementById(sugId) as HTMLElement | null;
    const latInput = document.getElementById(latId) as HTMLInputElement | null;
    const lngInput = document.getElementById(lngId) as HTMLInputElement | null;
    if (!input || !sug || !latInput || !lngInput) return;

    let timer: ReturnType<typeof setTimeout>;
    let lastQuery = "";

    const hide = () => { sug.hidden = true; sug.innerHTML = ""; };

    function pick(item: Suggestion) {
      input.value = item.display_name.split(",")[0].trim();
      latInput.value = item.lat;
      lngInput.value = item.lon;
      hide();
    }

    async function fetch_(q: string) {
      if (q === lastQuery) return;
      lastQuery = q;
      if (q.length < 3) { hide(); return; }
      try {
        const res = await fetch(
          `${NOMINATIM}?q=${encodeURIComponent(q + " Lahore")}&format=json&limit=5&addressdetails=0`,
          { headers: { "Accept-Language": "en" } },
        );
        const data: Suggestion[] = await res.json();
        if (!data.length) { hide(); return; }
        sug.innerHTML = data.map((item, i) =>
          `<li role="option" data-i="${i}" tabindex="-1">${item.display_name.split(",")[0].trim()}</li>`
        ).join("");
        (sug as any)._data = data;
        sug.hidden = false;
      } catch { hide(); }
    }

    input.addEventListener("input", () => {
      latInput.value = "";
      lngInput.value = "";
      clearTimeout(timer);
      timer = setTimeout(() => fetch_(input.value.trim()), 350);
    });

    sug.addEventListener("mousedown", (e) => {
      const li = (e.target as HTMLElement).closest("li");
      if (!li) return;
      const data = (sug as any)._data as Suggestion[];
      const i = parseInt(li.dataset.i ?? "0", 10);
      if (data?.[i]) pick(data[i]);
    });

    document.addEventListener("click", (e) => {
      if (!input.contains(e.target as Node) && !sug.contains(e.target as Node)) hide();
    });

    input.addEventListener("keydown", (e) => {
      if (sug.hidden) return;
      const items = Array.from(sug.querySelectorAll<HTMLElement>("li"));
      const current = sug.querySelector<HTMLElement>("li[aria-selected]");
      let idx = items.indexOf(current!);
      if (e.key === "ArrowDown") { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); idx = Math.max(idx - 1, 0); }
      else if (e.key === "Enter" && current) { e.preventDefault(); current.dispatchEvent(new MouseEvent("mousedown", { bubbles: true })); return; }
      else if (e.key === "Escape") { hide(); return; }
      else return;
      items.forEach((li) => li.removeAttribute("aria-selected"));
      items[idx]?.setAttribute("aria-selected", "true");
    });
  }

  setupAutocomplete("from", "from-suggestions", "fromLat", "fromLng");
  setupAutocomplete("to", "to-suggestions", "toLat", "toLng");

  const dayCbs = document.querySelectorAll<HTMLInputElement>("[data-day]");
  const daysHidden = document.getElementById("days-hidden") as HTMLInputElement | null;
  function syncDays() {
    if (!daysHidden) return;
    daysHidden.value = Array.from(dayCbs).filter(cb => cb.checked).map(cb => cb.value).join(",");
  }
  dayCbs.forEach(cb => cb.addEventListener("change", syncDays));

  const extraFilters = document.getElementById("extra-filters") as HTMLDetailsElement | null;
  const daysVal = (document.getElementById("days-hidden") as HTMLInputElement)?.value;
  const genderChecked = document.querySelector<HTMLInputElement>('input[name="genderPref"]:checked');
  if (extraFilters && (daysVal || (genderChecked && genderChecked.value))) {
    extraFilters.open = true;
  }
</script>

<style>
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.4rem;
    flex-wrap: wrap;
  }
  .page-head h1 { font-size: clamp(1.9rem, 4vw, 2.5rem); }
  .page-head .sub { margin-top: 0.35rem; }

  .filter {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 1.75rem;
    padding: 1rem 1.1rem;
  }
  .filter-hint { font-size: 0.88rem; margin: 0; }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.85rem;
  }
  .filter-field { flex: 1 1 13rem; }
  .filter-field-city { flex: 0 1 11rem; }
  .filter-field-city select { width: 100%; }
  .filter-field label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.3rem;
  }
  .ic { position: relative; }
  .ic input { padding-left: 1.7rem; }
  .pin {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    z-index: 1;
  }
  .pin.start { background: var(--green); }
  .pin.end { background: var(--amber); }

  .suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 30;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-top: none;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    box-shadow: var(--shadow);
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 220px;
    overflow-y: auto;
  }
  .suggestions li {
    padding: 0.6rem 0.85rem;
    font-size: 0.9rem;
    cursor: pointer;
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .suggestions li:last-child { border-bottom: none; }
  .suggestions li:hover,
  .suggestions li[aria-selected] { background: var(--green-soft); color: var(--green-ink); }

  .filter-actions { display: flex; gap: 0.5rem; }

  .extra-filters {
    border-top: 1px solid var(--line);
    margin: 0 -1.1rem -1rem;
    padding: 0 1.1rem;
  }
  .extra-toggle {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    cursor: pointer;
    list-style: none;
    padding: 0.65rem 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-2);
  }
  .extra-toggle::-webkit-details-marker { display: none; }
  .extra-toggle:hover { color: var(--ink); }
  .filter-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    margin-left: 2px;
  }
  .extra-content {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    padding-bottom: 0.85rem;
  }
  .extra-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .extra-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--ink-2);
  }
  .day-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .day-chip { margin: 0; cursor: pointer; user-select: none; }
  .day-chip input { position: absolute; opacity: 0; width: 0; height: 0; }
  .day-chip span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.8rem;
    padding: 0.35rem 0.6rem;
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .day-chip input:checked + span {
    background: linear-gradient(160deg, var(--green) 25%, var(--green-dk));
    border-color: var(--green-dk);
    color: #fff;
  }
  .pref-radios { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .pref-radio { margin: 0; cursor: pointer; user-select: none; }
  .pref-radio input { position: absolute; opacity: 0; width: 0; height: 0; }
  .pref-radio span {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .pref-radio input:checked + span {
    background: var(--green-soft);
    color: var(--green-ink);
    border-color: rgba(22,112,74,0.4);
  }

  .grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .notice {
    text-align: center;
    padding: 3rem 1.5rem;
  }
  .notice-emoji { font-size: 2.2rem; display: block; margin-bottom: 0.5rem; }
  .notice h3 { font-size: 1.3rem; }
  .notice p { margin: 0.5rem 0 0; }
  .notice.error {
    border-color: var(--danger-soft);
    background: linear-gradient(var(--danger-soft), var(--surface) 60%);
  }

  @media (max-width: 560px) {
    .filter-actions .btn { flex: 1; }
  }
</style>
