---
import Layout from "../../layouts/Layout.astro";
import { getDriver } from "../../lib/drivers";
import { whatsappHref, telHref } from "../../lib/contact";
import { getExistingRating } from "../../lib/ratings";

const { id } = Astro.params;
const driver = id ? await getDriver(id) : null;

if (!driver) {
  return Astro.redirect("/drivers");
}

const { userId } = Astro.locals.auth();
const isOwner = userId === driver.ownerId;
const existingRating = userId && !isOwner
  ? await getExistingRating(driver.id, userId).catch(() => null)
  : null;
const justRated = Astro.url.searchParams.get("rated") === "1";

const siteOrigin = new URL(Astro.request.url).origin;
const listingUrl = `${siteOrigin}/drivers/${driver.id}`;

const daysLabel =
  driver.days.length === 5 && ["Mon","Tue","Wed","Thu","Fri"].every(d => driver.days.includes(d))
    ? "Mon–Fri"
    : driver.days.join(", ");

// The share message drivers copy/send
const shareText = `I'm driving from ${driver.fromLocation} to ${driver.toLocation} on ${daysLabel}. I have ${driver.seats} seat${driver.seats !== 1 ? "s" : ""} open — join my carpool:\n${listingUrl}`;

const pageTitle = `${driver.seats} seat${driver.seats !== 1 ? "s" : ""} available: ${driver.fromLocation} → ${driver.toLocation} — Carpool`;
const pageDescription = `${driver.name} is driving from ${driver.fromLocation} to ${driver.toLocation} on ${daysLabel}. Departs ${driver.departTime || "—"}. ${driver.fare ? `Fare: ${driver.fare}.` : ""} Contact directly on Carpool — zero commission.`;

const waHref = whatsappHref(driver.phone, `Hi ${driver.name}, I found your ride from ${driver.fromLocation} to ${driver.toLocation} on Carpool. Is a seat still available?`);

const now = Date.now();
const isExpired = driver.expiresAt <= now;

const genderLabel =
  driver.genderPref === "female_only" ? "Female riders only"
  : driver.genderPref === "male_only" ? "Male riders only"
  : null;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`/drivers/${driver.id}`}
>
  <!-- Back link -->
  <a href="/drivers" class="back-link muted">← All rides</a>

  <div class="listing-wrap">
    <!-- Main card -->
    <article class="listing-card card">
      {isExpired && (
        <div class="expired-notice">
          This listing may have expired — try contacting the driver to confirm availability.
        </div>
      )}

      <header class="head">
        <span class="avatar">{(driver.name.trim()[0] ?? "?").toUpperCase()}</span>
        <div class="who">
          <h1 class="name">{driver.name}</h1>
          <p class="car muted">
            {[driver.carColor, driver.carMake, driver.carModel].filter(Boolean).join(" ")}
          </p>
        </div>
        <div class="head-badges">
          {driver.fare && <span class="fare">{driver.fare}</span>}
          {genderLabel && (
            <span class:list={["pref-badge", driver.genderPref]}>{genderLabel}</span>
          )}
        </div>
      </header>

      <!-- Route -->
      <div class="route">
        <div class="rail" aria-hidden="true">
          <span class="dot start"></span>
          <span class="line"></span>
          <span class="dot end"></span>
        </div>
        <div class="legs">
          <div class="leg">
            <span class="loc">{driver.fromLocation}</span>
            <span class="time muted">Departs {driver.departTime || "—"}</span>
          </div>
          {driver.stops.length > 0 && (
            <div class="via muted">via {driver.stops.join(" · ")}</div>
          )}
          <div class="leg">
            <span class="loc">{driver.toLocation}</span>
            {driver.returnTime && (
              <span class="time muted">Returns {driver.returnTime}</span>
            )}
          </div>
        </div>
      </div>

      <!-- Chips -->
      <div class="chips">
        <span class="chip">{driver.seats} {driver.seats === 1 ? "seat" : "seats"} available</span>
        {driver.days.length > 0 && <span class="chip">{daysLabel}</span>}
      </div>

      {driver.notes && <p class="notes">{driver.notes}</p>}

      <!-- Contact CTAs -->
      <div class="ctas">
        <a class="btn btn-success btn-lg" href={waHref} target="_blank" rel="noopener">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
            <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.5-3.9-4.7-4.1-.1-.2-1-1.4-1-2.6 0-1.2.6-1.8.9-2 .2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.5c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.2.1.4.2.4.3.1.2.1.8 0 1.2Z"/>
          </svg>
          Message on WhatsApp
        </a>
        <a class="btn btn-ghost btn-lg" href={telHref(driver.phone)}>
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7A2 2 0 0 1 22 16.9Z"/>
          </svg>
          Call
        </a>
      </div>
    </article>

    <!-- Share panel — the whole point of this page -->
    <aside class="share-panel card">
      <h2 class="share-heading">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        Share your open seats
      </h2>
      <p class="share-sub muted">Send this to your contacts, neighbourhood group or social feed.</p>

      <!-- Message preview -->
      <div class="message-preview" id="msg-preview">
        <p>{shareText.split("\n")[0]}</p>
        <p class="msg-link">{listingUrl}</p>
      </div>

      <!-- Share buttons -->
      <div class="share-btns">
        <!-- WhatsApp -->
        <a
          class="share-btn whatsapp"
          href={`https://wa.me/?text=${encodeURIComponent(shareText)}`}
          target="_blank"
          rel="noopener"
          aria-label="Share on WhatsApp"
        >
          <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor">
            <path d="M12 2a10 10 0 0 0-8.6 15l-1.3 4.7 4.8-1.3A10 10 0 1 0 12 2Zm5.3 14.1c-.2.6-1.3 1.2-1.8 1.2-.5.1-1 .2-3.3-.7-2.8-1.1-4.5-3.9-4.7-4.1-.1-.2-1-1.4-1-2.6 0-1.2.6-1.8.9-2 .2-.3.5-.3.7-.3h.5c.2 0 .4 0 .6.5l.8 2c.1.2.1.4 0 .5l-.4.5c-.2.2-.3.4-.1.7.2.3.8 1.3 1.7 2.1 1.2 1 2.1 1.4 2.4 1.5.2.1.4.1.6-.1l.7-.9c.2-.2.4-.2.6-.1l1.9.9c.2.1.4.2.4.3.1.2.1.8 0 1.2Z"/>
          </svg>
          <span>WhatsApp</span>
        </a>

        <!-- Twitter/X -->
        <a
          class="share-btn twitter"
          href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`${driver.fromLocation} → ${driver.toLocation} carpool — ${driver.seats} seat${driver.seats !== 1 ? "s" : ""} open on ${daysLabel}. Join me:`)}&url=${encodeURIComponent(listingUrl)}`}
          target="_blank"
          rel="noopener"
          aria-label="Share on X / Twitter"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L2.024 2.25H8.08l4.262 5.638zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
          <span>X / Twitter</span>
        </a>

        <!-- Facebook -->
        <a
          class="share-btn facebook"
          href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(listingUrl)}`}
          target="_blank"
          rel="noopener"
          aria-label="Share on Facebook"
        >
          <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          <span>Facebook</span>
        </a>

        <!-- Copy link -->
        <button
          class="share-btn copy"
          id="copy-btn"
          data-url={listingUrl}
          data-text={shareText}
          type="button"
          aria-label="Copy link"
        >
          <svg id="copy-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          <svg id="check-icon" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.5" hidden>
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span id="copy-label">Copy link</span>
        </button>
      </div>

      <!-- Native share (shown when supported) -->
      <button class="btn btn-primary native-share" id="native-share-btn" data-text={shareText} data-url={listingUrl} hidden>
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/>
        </svg>
        Share via…
      </button>

      <!-- Rating widget -->
      <div class="rating-section">
        <hr class="rating-divider" />

        {/* Current average */}
        {driver.ratingCount && driver.ratingCount > 0 ? (
          <div class="rating-display">
            <span class="stars-static" aria-label={`${driver.ratingAvg} out of 5`}>
              {[1,2,3,4,5].map(n => (
                <svg viewBox="0 0 20 20" width="18" height="18" aria-hidden="true"
                  class:list={["star-icon", { filled: n <= Math.round(driver.ratingAvg ?? 0) }]}>
                  <polygon points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"/>
                </svg>
              ))}
            </span>
            <span class="rating-label">
              <strong>{driver.ratingAvg?.toFixed(1)}</strong>
              <span class="muted">({driver.ratingCount} {driver.ratingCount === 1 ? "rating" : "ratings"})</span>
            </span>
          </div>
        ) : (
          <p class="muted no-ratings">No ratings yet — be the first.</p>
        )}

        {/* Rate form — signed-in non-owners only */}
        {justRated ? (
          <p class="rated-thanks">Thanks for rating!</p>
        ) : userId && !isOwner ? (
          <form method="POST" action="/api/ratings/submit" class="rate-form">
            <input type="hidden" name="driverId" value={driver.id} />
            <p class="rate-label">{existingRating ? "Update your rating:" : "Rate this driver:"}</p>
            <div class="star-picker" role="group" aria-label="Star rating">
              {[1,2,3,4,5].map(n => (
                <label class="star-label">
                  <input
                    type="radio"
                    name="stars"
                    value={n}
                    class="sr-only"
                    checked={existingRating?.stars === n}
                    required
                  />
                  <svg viewBox="0 0 20 20" width="28" height="28" aria-label={`${n} star${n !== 1 ? "s" : ""}`}
                    class:list={["star-pick", { prefilled: existingRating && n <= existingRating.stars }]}>
                    <polygon points="10,1 12.9,7 19.5,7.6 14.5,12 16.2,18.5 10,15 3.8,18.5 5.5,12 0.5,7.6 7.1,7"/>
                  </svg>
                </label>
              ))}
            </div>
            <button type="submit" class="btn btn-ghost btn-sm rate-submit">
              {existingRating ? "Update rating" : "Submit rating"}
            </button>
          </form>
        ) : !userId ? (
          <p class="muted rate-signin">
            <a href="/sign-in">Sign in</a> to leave a rating.
          </p>
        ) : null}
      </div>
    </aside>
  </div>

  <!-- Suggest more rides -->
  <div class="more-rides">
    <p class="muted">Looking for a different route?</p>
    <a href="/drivers" class="btn btn-ghost">Browse all rides</a>
    <a href="/requests/post" class="btn btn-ghost">Post a rider request</a>
  </div>
</Layout>

<script>
  // Native share API (mobile)
  const nativeBtn = document.getElementById("native-share-btn") as HTMLButtonElement | null;
  if (nativeBtn && navigator.share) {
    nativeBtn.hidden = false;
    nativeBtn.addEventListener("click", async () => {
      try {
        await navigator.share({
          title: document.title,
          text: nativeBtn.dataset.text ?? "",
          url: nativeBtn.dataset.url ?? location.href,
        });
      } catch {
        // User cancelled or browser blocked — no-op.
      }
    });
  }

  // Copy link / copy full message
  const copyBtn = document.getElementById("copy-btn") as HTMLButtonElement | null;
  const copyIcon = document.getElementById("copy-icon") as SVGElement | null;
  const checkIcon = document.getElementById("check-icon") as SVGElement | null;
  const copyLabel = document.getElementById("copy-label") as HTMLElement | null;

  copyBtn?.addEventListener("click", async () => {
    const text = copyBtn.dataset.text ?? copyBtn.dataset.url ?? location.href;
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      // Fallback for older browsers.
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
    }
    if (copyIcon) copyIcon.hidden = true;
    if (checkIcon) checkIcon.hidden = false;
    if (copyLabel) copyLabel.textContent = "Copied!";
    setTimeout(() => {
      if (copyIcon) copyIcon.hidden = false;
      if (checkIcon) checkIcon.hidden = true;
      if (copyLabel) copyLabel.textContent = "Copy link";
    }, 2200);
  });
</script>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .listing-wrap {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 1.4rem;
    align-items: start;
  }

  /* ── Listing card ── */
  .listing-card {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    padding: 1.8rem;
  }

  .expired-notice {
    background: var(--amber-soft);
    color: #7a4a10;
    font-size: 0.88rem;
    font-weight: 600;
    padding: 0.6rem 0.9rem;
    border-radius: var(--radius-sm);
    border: 1px solid rgba(216,132,42,0.3);
  }

  .head {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
  }
  .avatar {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    flex-shrink: 0;
    border-radius: 50%;
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.35rem;
    background: linear-gradient(150deg, var(--green) 25%, var(--green-dk));
  }
  .who { flex: 1; min-width: 0; }
  .name {
    font-size: 1.5rem;
    line-height: 1.1;
    margin: 0;
  }
  .car {
    font-size: 0.9rem;
    margin: 0.2rem 0 0;
    text-transform: capitalize;
  }
  .head-badges {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
    flex-shrink: 0;
  }
  .fare {
    background: var(--green-soft);
    color: var(--green-ink);
    font-weight: 700;
    font-size: 0.85rem;
    padding: 0.35rem 0.7rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .pref-badge {
    font-weight: 700;
    font-size: 0.76rem;
    padding: 0.28rem 0.6rem;
    border-radius: var(--radius-pill);
    white-space: nowrap;
  }
  .pref-badge.female_only { background: #fce8f3; color: #8b1a5a; }
  .pref-badge.male_only { background: #e8f0fc; color: #1a3d8b; }

  /* Route */
  .route { display: flex; gap: 1rem; }
  .rail {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 7px;
  }
  .dot {
    width: 13px;
    height: 13px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .dot.start { background: var(--green); }
  .dot.end { background: var(--amber); }
  .line {
    width: 2px;
    flex: 1;
    min-height: 32px;
    margin: 3px 0;
    background: repeating-linear-gradient(var(--line-2) 0 5px, transparent 5px 10px);
  }
  .legs { flex: 1; display: flex; flex-direction: column; gap: 0.65rem; }
  .leg { display: flex; flex-direction: column; }
  .loc { font-weight: 700; font-size: 1.1rem; }
  .time { font-size: 0.84rem; }
  .via { font-size: 0.84rem; padding-left: 0.15rem; }

  .chips { display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .chip {
    font-size: 0.84rem;
    font-weight: 600;
    color: var(--ink-2);
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 0.3rem 0.7rem;
    border-radius: var(--radius-pill);
  }

  .notes {
    margin: 0;
    font-size: 0.92rem;
    color: var(--ink-2);
    background: var(--paper);
    border-left: 3px solid var(--line-2);
    padding: 0.6rem 0.85rem;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  /* CTAs */
  .ctas {
    display: flex;
    gap: 0.65rem;
    flex-wrap: wrap;
    padding-top: 0.4rem;
    border-top: 1px solid var(--line);
  }
  .btn-lg {
    padding: 0.88rem 1.5rem;
    font-size: 1rem;
    flex: 1;
  }

  /* ── Share panel ── */
  .share-panel {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding: 1.5rem;
    background:
      radial-gradient(22rem 14rem at 110% -10%, var(--green-soft), transparent 60%),
      var(--surface);
  }

  .share-heading {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 1.15rem;
    margin: 0;
  }
  .share-sub { margin: -0.4rem 0 0; font-size: 0.88rem; }

  .message-preview {
    background: var(--paper);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-sm);
    padding: 0.85rem 1rem;
    font-size: 0.88rem;
    line-height: 1.5;
    color: var(--ink-2);
  }
  .message-preview p { margin: 0; }
  .msg-link {
    margin-top: 0.3rem !important;
    font-size: 0.78rem;
    color: var(--green);
    word-break: break-all;
  }

  .share-btns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.5rem;
  }
  .share-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.65rem 0.8rem;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    border: 1px solid transparent;
    text-decoration: none;
    transition: transform 0.15s ease, opacity 0.15s ease;
  }
  .share-btn:hover { transform: translateY(-1px); text-decoration: none; }
  .share-btn.whatsapp {
    background: #25d366;
    color: #fff;
  }
  .share-btn.twitter {
    background: #000;
    color: #fff;
  }
  .share-btn.facebook {
    background: #1877f2;
    color: #fff;
  }
  .share-btn.copy {
    background: var(--surface);
    color: var(--ink);
    border-color: var(--line-2);
    box-shadow: var(--shadow-sm);
  }
  .share-btn.copy:hover { border-color: var(--ink); }

  .native-share {
    width: 100%;
    justify-content: center;
    gap: 0.55rem;
  }

  /* More rides */
  .more-rides {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.65rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--line);
    font-size: 0.92rem;
  }
  .more-rides p { margin: 0; }

  /* Rating widget */
  .rating-section { margin-top: 0.25rem; }
  .rating-divider {
    border: none;
    border-top: 1px solid var(--line);
    margin: 1.1rem 0;
  }
  .rating-display {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 0.85rem;
  }
  .stars-static { display: flex; gap: 2px; }
  .star-icon polygon {
    fill: var(--line-2);
    transition: fill 0.1s;
  }
  .star-icon.filled polygon { fill: #f5a623; }
  .rating-label { font-size: 0.9rem; display: flex; align-items: center; gap: 0.35rem; }
  .no-ratings { font-size: 0.88rem; margin: 0 0 0.85rem; }
  .rated-thanks {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--green);
    margin: 0;
  }
  .rate-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-2);
    margin: 0 0 0.5rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
