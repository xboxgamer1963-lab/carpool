---
import Layout from "../../layouts/Layout.astro";
import DriverCard from "../../components/DriverCard.astro";
import RouteMap from "../../components/RouteMap.astro";
import { searchDrivers, type ScoredDriver } from "../../lib/drivers";

const url = new URL(Astro.request.url);
const p = url.searchParams;

// Coordinate-based search (from map/Nominatim)
const fromLat = parseFloat(p.get("fromLat") ?? "");
const fromLng = parseFloat(p.get("fromLng") ?? "");
const toLat = parseFloat(p.get("toLat") ?? "");
const toLng = parseFloat(p.get("toLng") ?? "");

// Text display / fallback
const fromText = p.get("from")?.trim() ?? "";
const toText = p.get("to")?.trim() ?? "";

// Filters
const daysParam = p.get("days")?.trim() ?? "";
const days = daysParam ? daysParam.split(",").filter(Boolean) : [];
const genderPref = p.get("genderPref")?.trim() ?? "";

const hasCoords =
  Number.isFinite(fromLat) && Number.isFinite(fromLng);
const hasQuery = hasCoords || Boolean(fromText || toText || days.length || genderPref);

let scored: ScoredDriver[] = [];
let error: string | null = null;
try {
  scored = await searchDrivers({
    fromLat: Number.isFinite(fromLat) ? fromLat : undefined,
    fromLng: Number.isFinite(fromLng) ? fromLng : undefined,
    toLat: Number.isFinite(toLat) ? toLat : undefined,
    toLng: Number.isFinite(toLng) ? toLng : undefined,
    fromText,
    toText,
    days: days.length ? days : undefined,
    genderPref: genderPref || undefined,
  });
} catch (e) {
  error = e instanceof Error ? e.message : "Could not load rides.";
}

const drivers = scored.map((s) => s.driver);
const hasNearMiss = scored.some((s) => s.isNearMiss);

const DAYS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
---

<Layout title="Available rides — Carpool">
  <header class="page-head">
    <div>
      <h1>{hasQuery ? "Matching rides" : "Available rides"}</h1>
      <p class="muted sub">
        {
          error
            ? "We couldn't reach the listings."
            : `${drivers.length} ${drivers.length === 1 ? "driver" : "drivers"} ${hasQuery ? "match your route" : "currently offering a carpool"}${hasNearMiss ? " (showing nearest matches)" : ""}`
        }
      </p>
    </div>
  </header>

  <!-- Search / filter form -->
  <form class="filter card" method="GET" action="/drivers" id="search-form">
    <div class="filter-row">
      <div class="filter-field">
        <label for="from">From</label>
        <div class="ic">
          <span class="pin start"></span>
          <input
            id="from"
            name="from"
            value={fromText}
            placeholder="Home area"
            autocomplete="off"
          />
          <input type="hidden" name="fromLat" id="fromLat" value={Number.isFinite(fromLat) ? fromLat : ""} />
          <input type="hidden" name="fromLng" id="fromLng" value={Number.isFinite(fromLng) ? fromLng : ""} />
          <ul class="suggestions" id="from-suggestions" hidden></ul>
        </div>
      </div>
      <div class="filter-field">
        <label for="to">To</label>
        <div class="ic">
          <span class="pin end"></span>
          <input
            id="to"
            name="to"
            value={toText}
            placeholder="Drop-off area"
            autocomplete="off"
          />
          <input type="hidden" name="toLat" id="toLat" value={Number.isFinite(toLat) ? toLat : ""} />
          <input type="hidden" name="toLng" id="toLng" value={Number.isFinite(toLng) ? toLng : ""} />
          <ul class="suggestions" id="to-suggestions" hidden></ul>
        </div>
      </div>
      <div class="filter-actions">
        <button type="submit" class="btn btn-primary">Search</button>
        {hasQuery && <a href="/drivers" class="btn btn-ghost">Clear</a>}
      </div>
    </div>

    <!-- Extra filters row -->
    <details class="extra-filters" id="extra-filters">
      <summary class="extra-toggle">
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 6h18M7 12h10M11 18h2"/>
        </svg>
        Filters
        {(days.length > 0 || genderPref) && <span class="filter-dot"></span>}
      </summary>
      <div class="extra-content">
        <div class="extra-group">
          <span class="extra-label">Days</span>
          <div class="day-chips">
            {DAYS.map((d) => (
              <label class="day-chip">
                <input
                  type="checkbox"
                  name="days-cb"
                  value={d}
                  checked={days.includes(d)}
                  data-day={d}
                />
                <span>{d}</span>
              </label>
            ))}
          </div>
          <input type="hidden" name="days" id="days-hidden" value={daysParam} />
        </div>
        <div class="extra-group">
          <span class="extra-label">Preference</span>
          <div class="pref-radios">
            {[
              { v: "", label: "Any" },
              { v: "female_only", label: "Female only" },
              { v: "male_only", label: "Male only" },
            ].map(({ v, label }) => (
              <label class="pref-radio">
                <input type="radio" name="genderPref" value={v} checked={genderPref === v} />
                <span>{label}</span>
              </label>
            ))}
          </div>
        </div>
      </div>
    </details>
  </form>

  {
    error ? (
      <div class="card notice error">
        <h3>Couldn't load rides</h3>
        <p class="muted">{error}</p>
      </div>
    ) : drivers.length === 0 ? (
      <div class="card notice">
        <span class="notice-emoji" aria-hidden="true">🛣️</span>
        <h3>No rides found{hasQuery ? " for that route" : " yet"}</h3>
        <p class="muted">
          Try a broader search, or{" "}
          <a href="/drivers/register">offer a ride</a> yourself.
        </p>
        {hasQuery && (
          <div class="request-cta">
            <p>Can't find a driver? Post a rider request so drivers can find you.</p>
            <a href="/requests/post" class="btn btn-primary btn-sm">Post a request</a>
          </div>
        )}
      </div>
    ) : (
      <>
        <div class="near-bar" id="near-bar" data-state="idle">
          <span class="nb-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 21s-7-5.2-7-11a7 7 0 1 1 14 0c0 5.8-7 11-7 11Z" stroke-linejoin="round"></path>
              <circle cx="12" cy="10" r="2.4"></circle>
            </svg>
          </span>
          <span class="nb-text">
            <strong>Find rides near you</strong>
            <span class="muted nb-sub">Sort drivers by how close their pickup is to you.</span>
          </span>
          <button type="button" id="near-enable" class="btn btn-primary btn-sm">
            Use my location
          </button>
          <button type="button" id="near-clear" class="btn btn-ghost btn-sm" hidden>
            Clear
          </button>
        </div>

        <RouteMap drivers={drivers} />

        <div class="grid" id="ride-grid">
          {scored.map(({ driver: d, detourKm, isNearMiss }) => (
            <div
              class="ride-anchor"
              id={`ride-${d.id}`}
              data-id={d.id}
              data-lat={d.fromLat ?? ""}
              data-lng={d.fromLng ?? ""}
            >
              <span class="distance" data-distance hidden></span>
              <DriverCard driver={d} detourKm={detourKm} isNearMiss={isNearMiss} />
            </div>
          ))}
        </div>

        {hasQuery && (
          <div class="also-requests">
            Also check{" "}
            <a href={`/requests?fromLat=${fromLat}&fromLng=${fromLng}&toLat=${toLat}&toLng=${toLng}&from=${encodeURIComponent(fromText)}&to=${encodeURIComponent(toText)}`}>
              riders looking for a driver
            </a>{" "}
            on your route.
          </div>
        )}
      </>
    )
  }
</Layout>

<script>
  // ── Nominatim autocomplete ──────────────────────────────────────────────────
  const NOMINATIM = "https://nominatim.openstreetmap.org/search";

  interface Suggestion { display_name: string; lat: string; lon: string; }

  function setupAutocomplete(
    inputId: string,
    sugId: string,
    latId: string,
    lngId: string,
  ) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    const sug = document.getElementById(sugId) as HTMLElement | null;
    const latInput = document.getElementById(latId) as HTMLInputElement | null;
    const lngInput = document.getElementById(lngId) as HTMLInputElement | null;
    if (!input || !sug || !latInput || !lngInput) return;

    let timer: ReturnType<typeof setTimeout>;
    let lastQuery = "";

    function hide() {
      sug.hidden = true;
      sug.innerHTML = "";
    }

    function pick(item: Suggestion) {
      input.value = item.display_name.split(",")[0].trim();
      latInput.value = item.lat;
      lngInput.value = item.lon;
      hide();
    }

    async function fetch_(q: string) {
      if (q === lastQuery) return;
      lastQuery = q;
      if (q.length < 3) { hide(); return; }
      try {
        const res = await fetch(
          `${NOMINATIM}?q=${encodeURIComponent(q + " Lahore")}&format=json&limit=5&addressdetails=0`,
          { headers: { "Accept-Language": "en" } },
        );
        const data: Suggestion[] = await res.json();
        if (data.length === 0) { hide(); return; }
        sug.innerHTML = data
          .map(
            (item, i) =>
              `<li role="option" data-i="${i}" tabindex="-1">${item.display_name.split(",")[0].trim()}</li>`,
          )
          .join("");
        (sug as any)._data = data;
        sug.hidden = false;
      } catch {
        hide();
      }
    }

    input.addEventListener("input", () => {
      // Clear coords when user types manually — they may be choosing a new place.
      latInput.value = "";
      lngInput.value = "";
      clearTimeout(timer);
      timer = setTimeout(() => fetch_(input.value.trim()), 350);
    });

    sug.addEventListener("mousedown", (e) => {
      const li = (e.target as HTMLElement).closest("li");
      if (!li) return;
      const i = parseInt(li.dataset.i ?? "0", 10);
      const data = (sug as any)._data as Suggestion[];
      if (data?.[i]) pick(data[i]);
    });

    document.addEventListener("click", (e) => {
      if (!input.contains(e.target as Node) && !sug.contains(e.target as Node)) {
        hide();
      }
    });

    // Keyboard navigation in suggestions
    input.addEventListener("keydown", (e) => {
      if (sug.hidden) return;
      const items = Array.from(sug.querySelectorAll<HTMLElement>("li"));
      const current = sug.querySelector<HTMLElement>("li[aria-selected]");
      let idx = items.indexOf(current!);
      if (e.key === "ArrowDown") { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); idx = Math.max(idx - 1, 0); }
      else if (e.key === "Enter" && current) { e.preventDefault(); current.dispatchEvent(new MouseEvent("mousedown", { bubbles: true })); return; }
      else if (e.key === "Escape") { hide(); return; }
      else return;
      items.forEach((li) => li.removeAttribute("aria-selected"));
      items[idx]?.setAttribute("aria-selected", "true");
    });
  }

  setupAutocomplete("from", "from-suggestions", "fromLat", "fromLng");
  setupAutocomplete("to", "to-suggestions", "toLat", "toLng");

  // ── Day-filter checkboxes → hidden input ────────────────────────────────────
  const dayCbs = document.querySelectorAll<HTMLInputElement>("[data-day]");
  const daysHidden = document.getElementById("days-hidden") as HTMLInputElement | null;
  function syncDays() {
    if (!daysHidden) return;
    const checked = Array.from(dayCbs)
      .filter((cb) => cb.checked)
      .map((cb) => cb.value);
    daysHidden.value = checked.join(",");
  }
  dayCbs.forEach((cb) => cb.addEventListener("change", syncDays));

  // Open extra filters if active on load
  const extraFilters = document.getElementById("extra-filters") as HTMLDetailsElement | null;
  const daysHiddenVal = (document.getElementById("days-hidden") as HTMLInputElement)?.value;
  const genderRadio = document.querySelector<HTMLInputElement>('input[name="genderPref"]:checked');
  if (extraFilters && (daysHiddenVal || (genderRadio && genderRadio.value))) {
    extraFilters.open = true;
  }

  // ── Proximity location sort (existing behaviour) ────────────────────────────
  const grid = document.getElementById("ride-grid");
  const bar = document.getElementById("near-bar");
  const enableBtn = document.getElementById("near-enable") as HTMLButtonElement | null;
  const clearBtn = document.getElementById("near-clear") as HTMLButtonElement | null;
  const headSub = document.querySelector(".page-head .sub");

  if (grid && bar) {
    const anchors = Array.from(grid.querySelectorAll<HTMLElement>(".ride-anchor"));
    const originalOrder = anchors.slice();
    const barText = bar.querySelector(".nb-text strong") as HTMLElement;
    const barSub = bar.querySelector(".nb-sub") as HTMLElement;

    const haversine = (lat1: number, lng1: number, lat2: number, lng2: number) => {
      const R = 6371;
      const dLat = ((lat2 - lat1) * Math.PI) / 180;
      const dLng = ((lng2 - lng1) * Math.PI) / 180;
      const a =
        Math.sin(dLat / 2) ** 2 +
        Math.cos((lat1 * Math.PI) / 180) *
          Math.cos((lat2 * Math.PI) / 180) *
          Math.sin(dLng / 2) ** 2;
      return 2 * R * Math.asin(Math.sqrt(a));
    };

    const fmt = (km: number) =>
      km < 1 ? `${Math.round(km * 1000)} m away` : `${km.toFixed(1)} km away`;

    function applyLocation(lat: number, lng: number) {
      bar.dataset.state = "on";
      barText.textContent = "Showing rides nearest to you";
      barSub.textContent = "Closest pickup points first.";
      enableBtn?.setAttribute("hidden", "");
      clearBtn?.removeAttribute("hidden");

      const withDist = anchors.map((el) => {
        const la = parseFloat(el.dataset.lat || "");
        const ln = parseFloat(el.dataset.lng || "");
        const badge = el.querySelector("[data-distance]") as HTMLElement;
        let dist = Infinity;
        if (Number.isFinite(la) && Number.isFinite(ln)) {
          dist = haversine(lat, lng, la, ln);
          badge.textContent = fmt(dist);
          badge.hidden = false;
        } else {
          badge.hidden = true;
        }
        return { el, dist };
      });

      withDist.sort((a, b) => a.dist - b.dist);
      withDist.forEach(({ el }) => grid!.appendChild(el));

      if (headSub) {
        const n = withDist.filter((d) => d.dist !== Infinity).length;
        headSub.textContent = `${n} ${n === 1 ? "ride" : "rides"} sorted by distance from you`;
      }
      window.dispatchEvent(new CustomEvent("carpool:userlocation", { detail: { lat, lng } }));
    }

    function clearLocation() {
      bar.dataset.state = "idle";
      barText.textContent = "Find rides near you";
      barSub.textContent = "Sort drivers by how close their pickup is to you.";
      enableBtn?.removeAttribute("hidden");
      clearBtn?.setAttribute("hidden", "");
      anchors.forEach((el) => {
        const badge = el.querySelector("[data-distance]") as HTMLElement;
        badge.hidden = true;
      });
      originalOrder.forEach((el) => grid!.appendChild(el));
      window.dispatchEvent(new CustomEvent("carpool:userlocation:clear"));
    }

    function requestLocation() {
      if (!navigator.geolocation) {
        bar.dataset.state = "error";
        barSub.textContent = "Location isn't available in this browser.";
        return;
      }
      bar.dataset.state = "loading";
      barSub.textContent = "Getting your location…";
      navigator.geolocation.getCurrentPosition(
        (pos) => applyLocation(pos.coords.latitude, pos.coords.longitude),
        () => {
          bar.dataset.state = "error";
          barText.textContent = "Find rides near you";
          barSub.textContent = "We couldn't get your location — you can still browse all rides.";
        },
        { enableHighAccuracy: true, timeout: 8000 },
      );
    }

    enableBtn?.addEventListener("click", requestLocation);
    clearBtn?.addEventListener("click", clearLocation);

    const params = new URLSearchParams(location.search);
    const qLat = parseFloat(params.get("lat") || "");
    const qLng = parseFloat(params.get("lng") || "");
    if (Number.isFinite(qLat) && Number.isFinite(qLng)) {
      applyLocation(qLat, qLng);
    } else {
      requestLocation();
    }
  }
</script>

<style>
  .page-head { margin-bottom: 1.4rem; }
  .page-head h1 { font-size: clamp(1.9rem, 4vw, 2.5rem); }
  .page-head .sub { margin-top: 0.35rem; }

  .filter {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 1.75rem;
    padding: 1rem 1.1rem;
  }
  .filter-row {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.85rem;
  }
  .filter-field { flex: 1 1 13rem; }
  .filter-field label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.3rem;
  }
  .ic { position: relative; }
  .ic input { padding-left: 1.7rem; }
  .pin {
    position: absolute;
    left: 0.7rem;
    top: 50%;
    transform: translateY(-50%);
    width: 9px;
    height: 9px;
    border-radius: 50%;
    z-index: 1;
  }
  .pin.start { background: var(--green); }
  .pin.end { background: var(--amber); }

  /* Autocomplete suggestions */
  .suggestions {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 30;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-top: none;
    border-radius: 0 0 var(--radius-sm) var(--radius-sm);
    box-shadow: var(--shadow);
    list-style: none;
    margin: 0;
    padding: 0;
    max-height: 220px;
    overflow-y: auto;
  }
  .suggestions li {
    padding: 0.6rem 0.85rem;
    font-size: 0.9rem;
    cursor: pointer;
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .suggestions li:last-child { border-bottom: none; }
  .suggestions li:hover,
  .suggestions li[aria-selected] {
    background: var(--green-soft);
    color: var(--green-ink);
  }

  .filter-actions { display: flex; gap: 0.5rem; }

  /* Extra filters */
  .extra-filters {
    border-top: 1px solid var(--line);
    margin: 0 -1.1rem -1rem;
    padding: 0 1.1rem;
  }
  .extra-toggle {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    cursor: pointer;
    list-style: none;
    padding: 0.65rem 0;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-2);
    position: relative;
  }
  .extra-toggle::-webkit-details-marker { display: none; }
  .extra-toggle:hover { color: var(--ink); }
  .filter-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    margin-left: 2px;
  }
  .extra-content {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 1.5rem;
    padding-bottom: 0.85rem;
  }
  .extra-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .extra-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
    color: var(--ink-2);
  }
  .day-chips { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .day-chip { margin: 0; cursor: pointer; user-select: none; }
  .day-chip input { position: absolute; opacity: 0; width: 0; height: 0; }
  .day-chip span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.8rem;
    padding: 0.35rem 0.6rem;
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .day-chip input:checked + span {
    background: linear-gradient(160deg, var(--green) 25%, var(--green-dk));
    border-color: var(--green-dk);
    color: #fff;
  }
  .pref-radios { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .pref-radio { margin: 0; cursor: pointer; user-select: none; }
  .pref-radio input { position: absolute; opacity: 0; width: 0; height: 0; }
  .pref-radio span {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.75rem;
    font-weight: 600;
    font-size: 0.82rem;
    color: var(--ink-2);
    background: var(--paper-2);
    border: 1px solid var(--line-2);
    border-radius: var(--radius-pill);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .pref-radio input:checked + span {
    background: var(--green-soft);
    color: var(--green-ink);
    border-color: rgba(22,112,74,0.4);
  }

  .grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .near-bar {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.9rem 1.1rem;
    margin-bottom: 1.25rem;
    background:
      radial-gradient(20rem 10rem at 0% 0%, var(--green-soft), transparent 70%),
      var(--surface);
    border: 1px solid var(--line-2);
    border-radius: var(--radius);
    box-shadow: var(--shadow-sm);
  }
  .nb-icon {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    flex-shrink: 0;
    border-radius: 10px;
    color: var(--green);
    background: var(--green-soft);
  }
  .near-bar[data-state="on"] .nb-icon {
    color: #fff;
    background: linear-gradient(150deg, var(--green), var(--green-dk));
  }
  .nb-text { display: flex; flex-direction: column; line-height: 1.3; }
  .nb-text strong { font-size: 0.98rem; }
  .nb-sub { font-size: 0.84rem; }
  .near-bar .btn { margin-left: auto; flex-shrink: 0; }
  .near-bar #near-clear { margin-left: 0; }
  .near-bar[data-state="loading"] #near-enable { opacity: 0.6; pointer-events: none; }

  .ride-anchor {
    position: relative;
    display: flex;
    cursor: pointer;
    border-radius: var(--radius);
    transition: box-shadow 0.2s ease;
  }
  .distance {
    position: absolute;
    top: -10px;
    left: 14px;
    z-index: 2;
    background: linear-gradient(150deg, var(--green), var(--green-dk));
    color: #fff;
    font-size: 0.74rem;
    font-weight: 700;
    padding: 0.22rem 0.6rem;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-sm);
    border: 1.5px solid var(--surface);
  }
  .ride-anchor > :global(.driver) { width: 100%; }
  .ride-anchor.is-active > :global(.driver) {
    border-color: var(--green);
    box-shadow: 0 0 0 2px var(--green), var(--shadow-lg);
  }

  .notice {
    text-align: center;
    padding: 3rem 1.5rem;
  }
  .notice-emoji { font-size: 2.2rem; display: block; margin-bottom: 0.5rem; }
