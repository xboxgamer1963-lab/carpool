---
import Layout from "../../layouts/Layout.astro";
import DriverCard from "../../components/DriverCard.astro";
import { getDriversByOwner } from "../../lib/drivers";

const { userId } = Astro.locals.auth();
// middleware guarantees a userId here, but guard anyway.
let drivers = [];
let error: string | null = null;
if (userId) {
  try {
    drivers = await getDriversByOwner(userId);
  } catch (e) {
    error = e instanceof Error ? e.message : "Could not load your rides.";
  }
}
---

<Layout title="My rides — Carpool">
  <header class="page-head">
    <div>
      <h1>My rides</h1>
      <p class="muted sub">Listings you've published.</p>
    </div>
    <a href="/drivers/register" class="btn btn-primary">Offer another ride</a>
  </header>

  {
    error ? (
      <div class="card notice">{error}</div>
    ) : drivers.length === 0 ? (
      <div class="card notice">
        <span class="notice-emoji" aria-hidden="true">🚗</span>
        <h3>No rides yet</h3>
        <p class="muted">
          <a href="/drivers/register">Offer a ride</a> to let commuters find you.
        </p>
      </div>
    ) : (
      <div class="grid">
        {drivers.map((d) => <DriverCard driver={d} owned />)}
      </div>
    )
  }
</Layout>

<style>
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.6rem;
  }
  .page-head h1 {
    font-size: clamp(1.9rem, 4vw, 2.5rem);
  }
  .page-head .sub {
    margin-top: 0.35rem;
  }

  .grid {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }

  .notice {
    text-align: center;
    padding: 3rem 1.5rem;
  }
  .notice-emoji {
    font-size: 2.2rem;
    display: block;
    margin-bottom: 0.5rem;
  }
  .notice h3 {
    font-size: 1.3rem;
  }
  .notice p {
    margin: 0.5rem 0 0;
  }

  @media (max-width: 520px) {
    .page-head {
      flex-direction: column;
      align-items: stretch;
    }
    .page-head .btn {
      width: 100%;
    }
  }
</style>
