---
import type { Driver } from "../lib/drivers";

interface Props {
  drivers: Driver[];
}
const { drivers } = Astro.props;

// Only rides with coordinates can be plotted.
const mapped = drivers
  .filter((d) => d.fromLat != null && d.fromLng != null)
  .map((d) => ({
    id: d.id,
    name: d.name,
    car: [d.carColor, d.carMake, d.carModel].filter(Boolean).join(" "),
    seats: d.seats,
    from: d.fromLocation,
    to: d.toLocation,
    depart: d.departTime,
    fare: d.fare,
    fromLat: d.fromLat,
    fromLng: d.fromLng,
    toLat: d.toLat,
    toLng: d.toLng,
  }));

const hiddenCount = drivers.length - mapped.length;
---

<div class="map-shell">
  <div class="map-canvas" id="route-map" data-empty={mapped.length === 0}></div>
  <div class="map-legend">
    <span><i class="lg start"></i> Pickup</span>
    <span><i class="lg end"></i> Drop-off</span>
    <span class="muted hint">Tap a car to drive the route</span>
  </div>
  {
    hiddenCount > 0 && (
      <p class="map-note muted">
        {hiddenCount} {hiddenCount === 1 ? "ride isn't" : "rides aren't"} pinned to
        the map yet.
      </p>
    )
  }
</div>

<script
  type="application/json"
  id="route-data"
  set:html={JSON.stringify(mapped)}
/>

<script>
  import maplibregl from "maplibre-gl";
  import "maplibre-gl/dist/maplibre-gl.css";

  type Ride = {
    id: string;
    name: string;
    car: string;
    seats: number;
    from: string;
    to: string;
    depart: string;
    fare: string;
    fromLat: number;
    fromLng: number;
    toLat: number | null;
    toLng: number | null;
  };

  const el = document.getElementById("route-map") as HTMLElement | null;
  const dataEl = document.getElementById("route-data");
  if (el && dataEl) {
    const rides: Ride[] = JSON.parse(dataEl.textContent || "[]");

    const map = new maplibregl.Map({
      container: el,
      style: "https://tiles.openfreemap.org/styles/positron",
      center: [67.0, 24.86],
      zoom: 11,
      attributionControl: { compact: true },
    });
    map.scrollZoom.disable();
    map.addControl(
      new maplibregl.NavigationControl({ showCompass: false, visualizePitch: false }),
      "top-right"
    );

    const pinEl = (cls: string) => {
      const wrap = document.createElement("div");
      wrap.innerHTML = `<span class="pin-marker ${cls}"></span>`;
      return wrap.firstElementChild as HTMLElement;
    };
    const carEl = () => {
      const wrap = document.createElement("div");
      wrap.innerHTML = `<span class="car-marker">${CAR_SVG}</span>`;
      return wrap.firstElementChild as HTMLElement;
    };

    const bounds = new maplibregl.LngLatBounds();
    const carMarkers: Record<string, maplibregl.Marker> = {};
    const ridesById: Record<string, Ride> = {};
    let activeAnim: number | null = null;
    let activeLineId: string | null = null;

    const lineSourceId = (id: string) => `ride-line-${id}`;
    const lineLayerId = (id: string) => `ride-line-layer-${id}`;

    const lineFeature = (a: [number, number], b: [number, number]) => ({
      type: "Feature" as const,
      properties: {},
      geometry: {
        type: "LineString" as const,
        coordinates: [a, b],
      },
    });

    const initMap = () => {
      rides.forEach((r) => {
        ridesById[r.id] = r;
        const start: [number, number] = [r.fromLng, r.fromLat];
        bounds.extend(start);

        const hasEnd = r.toLat != null && r.toLng != null;
        const end: [number, number] | null = hasEnd
          ? [r.toLng as number, r.toLat as number]
          : null;

        if (end) {
          const srcId = lineSourceId(r.id);
          const lyrId = lineLayerId(r.id);
          map.addSource(srcId, {
            type: "geojson",
            data: {
              type: "FeatureCollection",
              features: [lineFeature(start, end)],
            },
          });
          map.addLayer({
            id: lyrId,
            type: "line",
            source: srcId,
            layout: { "line-cap": "round" },
            paint: {
              "line-color": "#16704a",
              "line-width": 2.5,
              "line-opacity": 0.35,
              "line-dasharray": [2, 4],
            },
          });
          bounds.extend(end);
          new maplibregl.Marker({ element: pinEl("end"), anchor: "bottom" })
            .setLngLat(end)
            .addTo(map);
        }

        const popup = new maplibregl.Popup({
          className: "ride-popup",
          maxWidth: "240px",
          offset: 18,
          closeButton: false,
        }).setHTML(popupHtml(r));

        const car = new maplibregl.Marker({
          element: carEl(),
          anchor: "center",
        })
          .setLngLat(start)
          .setPopup(popup)
          .addTo(map);
        carMarkers[r.id] = car;

        car.getElement().addEventListener("click", (e) => {
          e.stopPropagation();
          focusRide(r);
        });
      });

      if (!bounds.isEmpty()) {
        map.fitBounds(bounds, { padding: 48, maxZoom: 14, duration: 0 });
      } else {
        map.setCenter([67.0, 24.86]);
        map.setZoom(11);
      }
    };

    // Layers/sources must be added after the style finishes loading.
    if (map.isStyleLoaded()) initMap();
    else map.once("load", initMap);

    function focusRide(r: Ride) {
      const car = carMarkers[r.id];
      if (!car) return;
      map.panTo(car.getLngLat(), { animate: true });
      const popup = car.getPopup();
      if (popup && !popup.isOpen()) car.togglePopup();
      highlightCard(r.id);
      if (r.toLat != null && r.toLng != null) {
        driveRoute(r);
      }
    }

    function setLineActive(id: string, active: boolean) {
      const layer = lineLayerId(id);
      if (!map.getLayer(layer)) return;
      map.setPaintProperty(layer, "line-opacity", active ? 0.85 : 0.35);
      map.setPaintProperty(layer, "line-width", active ? 3.5 : 2.5);
    }

    function driveRoute(r: Ride) {
      const car = carMarkers[r.id];
      if (!car || r.toLat == null || r.toLng == null) return;
      if (activeAnim) cancelAnimationFrame(activeAnim);
      if (activeLineId && activeLineId !== r.id) setLineActive(activeLineId, false);

      const fromLng = r.fromLng;
      const fromLat = r.fromLat;
      const toLng = r.toLng;
      const toLat = r.toLat;
      const duration = 2200;
      const startT = performance.now();

      activeLineId = r.id;
      setLineActive(r.id, true);

      const tick = (now: number) => {
        const t = Math.min(1, (now - startT) / duration);
        const ease = t < 0.5 ? 2 * t * t : 1 - Math.pow(-2 * t + 2, 2) / 2;
        const lat = fromLat + (toLat - fromLat) * ease;
        const lng = fromLng + (toLng - fromLng) * ease;
        car.setLngLat([lng, lat]);
        if (t < 1) {
          activeAnim = requestAnimationFrame(tick);
        } else {
          setTimeout(() => {
            car.setLngLat([fromLng, fromLat]);
            setLineActive(r.id, false);
            if (activeLineId === r.id) activeLineId = null;
          }, 700);
        }
      };
      activeAnim = requestAnimationFrame(tick);
    }

    function highlightCard(id: string) {
      const card = document.getElementById(`ride-${id}`);
      if (!card) return;
      document
        .querySelectorAll(".ride-anchor.is-active")
        .forEach((n) => n.classList.remove("is-active"));
      card.classList.add("is-active");
      card.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    document.querySelectorAll<HTMLElement>(".ride-anchor").forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
        const target = e.target as HTMLElement;
        if (target.closest("a, button")) return;
        const id = anchor.dataset.id;
        const ride = id ? ridesById[id] : undefined;
        if (ride) {
          el!.scrollIntoView({ behavior: "smooth", block: "start" });
          focusRide(ride);
        }
      });
    });

    // ---- "You are here" marker, driven by the page's geolocation ----------
    let userMarker: maplibregl.Marker | null = null;
    let userRing: maplibregl.Marker | null = null;
    const ringEl = () => {
      const wrap = document.createElement("div");
      wrap.innerHTML = '<span class="you-ring"></span>';
      return wrap.firstElementChild as HTMLElement;
    };
    const youEl = () => {
      const wrap = document.createElement("div");
      wrap.innerHTML = '<span class="you-marker" title="You are here"></span>';
      return wrap.firstElementChild as HTMLElement;
    };

    window.addEventListener("carpool:userlocation", (ev) => {
      const { lat, lng } = (ev as CustomEvent).detail as {
        lat: number;
        lng: number;
      };
      const pos: [number, number] = [lng, lat];
      if (!userMarker) {
        userRing = new maplibregl.Marker({ element: ringEl(), anchor: "center" })
          .setLngLat(pos)
          .addTo(map);
        const popup = new maplibregl.Popup({ offset: 14, closeButton: false }).setText(
          "You are here"
        );
        userMarker = new maplibregl.Marker({ element: youEl(), anchor: "center" })
          .setLngLat(pos)
          .setPopup(popup)
          .addTo(map);
      } else {
        userMarker.setLngLat(pos);
        userRing?.setLngLat(pos);
      }
      // Recenter to include the visitor and a handful of nearest rides.
      const near = new maplibregl.LngLatBounds();
      near.extend(pos);
      rides.slice(0, 5).forEach((r) => near.extend([r.fromLng, r.fromLat]));
      map.fitBounds(near, { padding: 60, maxZoom: 13 });
    });
    window.addEventListener("carpool:userlocation:clear", () => {
      if (userMarker) {
        userMarker.remove();
        userMarker = null;
      }
      if (userRing) {
        userRing.remove();
        userRing = null;
      }
      if (!bounds.isEmpty()) map.fitBounds(bounds, { padding: 48, maxZoom: 14 });
    });

    function popupHtml(r: Ride) {
      return `
        <div class="rp">
          <strong class="rp-name">${escapeHtml(r.name)}</strong>
          <span class="rp-car">${escapeHtml(r.car)}</span>
          <div class="rp-route">
            <span>${escapeHtml(r.from)}</span> → <span>${escapeHtml(r.to)}</span>
          </div>
          <div class="rp-meta">${r.seats} seats${r.depart ? " · " + escapeHtml(r.depart) : ""}${r.fare ? " · " + escapeHtml(r.fare) : ""}</div>
        </div>`;
    }

    function escapeHtml(s: string) {
      const d = document.createElement("div");
      d.textContent = s;
      return d.innerHTML;
    }
  }

  const CAR_SVG = `<svg viewBox="0 0 40 24" width="40" height="24" xmlns="http://www.w3.org/2000/svg">
    <g>
      <path d="M3 16c-1.1 0-2-.9-2-2v-1.5c0-.8.4-1.5 1.1-1.9l3-1.7 3.2-3.1C9 4.3 9.9 4 10.8 4h13.4c.9 0 1.8.4 2.4 1.1l3.4 4 5.1 1.2c1.1.3 1.9 1.3 1.9 2.4V14c0 1.1-.9 2-2 2H3Z" fill="#16704a"/>
      <path d="M11 5.5h12.6c.6 0 1.1.2 1.5.7l2.7 3.1H8.2l2-2.7c.2-.7.4-1.1.8-1.1Z" fill="#cfe7d6"/>
      <circle cx="11" cy="16.5" r="3.2" fill="#1d1b14"/>
      <circle cx="11" cy="16.5" r="1.3" fill="#fff"/>
      <circle cx="29" cy="16.5" r="3.2" fill="#1d1b14"/>
      <circle cx="29" cy="16.5" r="1.3" fill="#fff"/>
    </g>
  </svg>`;
</script>

<style>
  .map-shell {
    margin-bottom: 1.75rem;
  }
  .map-canvas {
    height: 420px;
    width: 100%;
    border-radius: var(--radius);
    border: 1px solid var(--line-2);
    box-shadow: var(--shadow);
    background: #eef1ee;
    z-index: 0;
    overflow: hidden;
  }
  .map-canvas[data-empty="true"] {
    display: grid;
    place-items: center;
  }
  .map-legend {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: 0.7rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ink-2);
  }
  .map-legend i.lg {
    display: inline-block;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    margin-right: 0.3rem;
    vertical-align: middle;
  }
  .map-legend i.start {
    background: var(--green);
  }
  .map-legend i.end {
    background: var(--amber);
  }
  .map-legend .hint {
    margin-left: auto;
    font-weight: 500;
  }
  .map-note {
    margin: 0.5rem 0 0;
    font-size: 0.85rem;
  }

  @media (max-width: 640px) {
    .map-canvas {
      height: 320px;
    }
    .map-legend .hint {
      display: none;
    }
  }

  /* Marker visuals (global so the HTML inside marker elements is styled) */
  :global(.pin-marker) {
    display: block;
    width: 16px;
    height: 16px;
    border-radius: 50% 50% 50% 0;
    transform: rotate(-45deg);
    border: 2.5px solid #fff;
    box-shadow: 0 2px 6px rgba(20, 30, 20, 0.4);
  }
  :global(.pin-marker.start) {
    background: var(--green);
  }
  :global(.pin-marker.end) {
    background: var(--amber);
  }
  :global(.you-marker) {
    display: block;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: #2563eb;
    border: 3px solid #fff;
    box-shadow: 0 2px 6px rgba(20, 30, 60, 0.45);
    animation: youpulse 2s ease-in-out infinite;
  }
  :global(.you-ring) {
    display: block;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(37, 99, 235, 0.14);
    pointer-events: none;
  }
  @keyframes youpulse {
    0%,
    100% {
      box-shadow: 0 2px 6px rgba(20, 30, 60, 0.45), 0 0 0 0 rgba(37, 99, 235, 0.4);
    }
    50% {
      box-shadow: 0 2px 6px rgba(20, 30, 60, 0.45), 0 0 0 8px rgba(37, 99, 235, 0);
    }
  }
  :global(.car-marker) {
    display: block;
    filter: drop-shadow(0 3px 4px rgba(20, 30, 20, 0.35));
    transition: transform 0.15s ease;
    cursor: pointer;
  }
  :global(.car-marker:hover) {
    transform: scale(1.15);
  }

  /* Popup styling — MapLibre uses its own class names */
  :global(.ride-popup .maplibregl-popup-content) {
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    padding: 0.7rem 0.85rem;
    font-family: var(--font-body);
  }
  :global(.ride-popup .maplibregl-popup-tip) {
    border-top-color: #fff;
    border-bottom-color: #fff;
  }
  :global(.rp-name) {
    font-family: var(--font-display);
    font-size: 1rem;
  }
  :global(.rp-car) {
    display: block;
    font-size: 0.8rem;
    color: var(--ink-2);
    text-transform: capitalize;
    margin-bottom: 0.35rem;
  }
  :global(.rp-route) {
    font-weight: 600;
    font-size: 0.9rem;
  }
  :global(.rp-meta) {
    font-size: 0.8rem;
    color: var(--ink-2);
    margin-top: 0.2rem;
  }
</style>
